{
	"$schema": "https://json.schemastore.org/prettierrc",
	"tabWidth": 8,
	"useTabs": true,
	"semi": true,
	"singleQuote": true,
	"quoteProps": "as-needed",
	"trailingComma": "es5",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"arrowParens": "always",
	"printWidth": 250,
	"endOfLine": "lf"
}
