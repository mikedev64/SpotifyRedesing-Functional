	"version": "1.0.0",
	"description": "Clon de la plataforma de musica Spotify",
	"type": "module",
	"scripts": {
		"int:dev": "npm run dev -w Interface",
		"app:dev": "npm run start -w Application",
		"srv:dev": "npm run start -w Server",
		"build": "tsc --build",
		"build:clean": "tsc --build --clean",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
